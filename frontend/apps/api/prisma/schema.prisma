generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum SubscriptionStatus {
  free
  trial
  active
  expired
}

enum ProjectStatus {
  draft
  queued
  processing
  ready
  error
}

enum AudioStatus {
  queued
  processing
  ready
  error
}

enum VoiceGender {
  male
  female
  neutral
}

enum VoiceRole {
  narrator  // Диктор
  actor     // Актер (для мужских и женских голосов)
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  passwordHash       String
  role               UserRole           @default(user)
  subscriptionStatus SubscriptionStatus @default(free)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  projects           Project[]
  audios             Audio[]
  refreshTokens      RefreshToken[]
  subscription       Subscription?
  books              Book[]
  bookSeries         BookSeries[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Project {
  id           String        @id @default(cuid())
  userId       String
  title        String
  text         String
  language     String
  status       ProjectStatus @default(draft)
  errorMessage String?
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  voices ProjectVoice[]
  audios Audio[]

  @@index([userId])
}

model Voice {
  id                  String      @id @default(cuid())
  name                String
  role                VoiceRole   @default(actor)
  gender              VoiceGender
  language            String
  style               String
  provider            String
  providerVoiceId     String
  sampleStorageKey    String?
  characterDescription String?   // описание характера персонажа
  isActive            Boolean     @default(true)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  projects ProjectVoice[]

  @@unique([provider, providerVoiceId])
  @@index([role])
}

model ProjectVoice {
  id          String  @id @default(cuid())
  projectId   String
  voiceId     String
  roleLabel   String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  voice   Voice   @relation(fields: [voiceId], references: [id], onDelete: Restrict)

  @@unique([projectId, voiceId])
  @@index([projectId])
  @@index([voiceId])
}

model Audio {
  id              String      @id @default(cuid())
  projectId        String
  userId           String
  status           AudioStatus @default(queued)
  storageKey       String?
  durationSeconds  Int?
  format           String?     // mp3/ogg/wav
  errorMessage     String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
}

model Plan {
  id                 String   @id @default(cuid())
  name               String   @unique
  monthlyPriceCents  Int
  maxCharactersMonth Int
  canDownload        Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                 String   @id @default(cuid())
  userId             String   @unique
  planId             String?
  status             SubscriptionStatus @default(free)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  providerCustomerId String?
  providerSubscriptionId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan? @relation(fields: [planId], references: [id], onDelete: SetNull)
}

model BookSeries {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  books Book[]

  @@index([userId])
}

model Book {
  id               String    @id @default(cuid())
  userId           String
  title            String
  description      String?
  author           String?
  genre            String?
  seriesId        String?
  seriesOrder      Int?
  coverStorageKey  String?
  appBookId        String?   // ID книги в App API для воспроизведения/скачивания
  audiobookFolder  String?   // папка в storage/audiobooks/{user_id}/{folder} после finalize
  language         String    @default("ru")
  completedAt      DateTime?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  series BookSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([seriesId])
}

