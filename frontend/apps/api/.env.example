PORT=4000
NODE_ENV=development

DATABASE_URL=postgresql://neuro:neuro@localhost:5432/neurochtec?schema=public
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=neurochtec-audio

# Product limits (MVP)
FREE_MAX_CHARS_PER_REQUEST=6000
FREE_MAX_REQUESTS_PER_DAY=5

